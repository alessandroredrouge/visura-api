# Variabili d'ambiente per il servizio Visura API
# Copia questo file in .env e inserisci le tue credenziali:
#   cp .env.example .env

# === Metodo di login ===
# 'sielte' = SPID via Sielte ID (default)
# 'cie'    = CIE (Carta d'Identità Elettronica) con OTP via SMS
# 'poste'  = SPID via PosteID (notifica app + FaceID)
LOGIN_METHOD=sielte

# === Credenziali Agenzia delle Entrate ===
# Per Sielte: ADE_USERNAME = Codice Fiscale / Partita IVA, ADE_PASSWORD = password SPID
# Per CIE:    ADE_USERNAME = Numero CIE / Codice Fiscale / Email, ADE_PASSWORD = password CIE
# Per Poste:  ADE_EMAIL = email PosteID, ADE_PASSWORD = password PosteID
ADE_USERNAME=il_tuo_codice_fiscale
ADE_PASSWORD=la_tua_password
ADE_EMAIL=la_tua_email_posteid
ADE_EMAIL=la_tua_email
# === Configurazione opzionale ===

# Livello di log: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Numero di worker concorrenti
CONCURRENT_WORKERS=3

# Non modificare queste (necessarie per Playwright in Docker)
PYTHONUNBUFFERED=1
DISPLAY=:99
